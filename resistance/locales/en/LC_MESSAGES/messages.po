msgstr "There is no active vote."

msgid "stats.reminder"
msgstr "Please vote: {players}"

msgid "stats.summary"
msgstr "Your games: {games}\nWins: {wins}\n\nGroup games: {group_games}\nGood-side wins: {villager_wins}\nHidden-side wins: {werewolf_wins}"

msgid "language.choose"
msgstr "Choose a language:"

msgid "language.saved"
msgstr "Your language: {language}."

msgid "language.group_saved"
msgstr "Group language: {language}."

msgid "language.admin_only"
msgstr "Only group administrators can change the group language."

msgid "label.classic.villager"
msgstr "Resistance member"

msgid "label.classic.werewolf"
msgstr "Spy"

