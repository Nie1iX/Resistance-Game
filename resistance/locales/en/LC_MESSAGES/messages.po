msgid "start.description"
msgstr "Resistance is a social deduction game for 5-10 players. Add the bot to a group and use the button below or /newgame."

msgid "help.commands"
msgstr "Commands: /newgame, /join, /missions, /startgame, /cancelgame, /board, /votes, /calltovote, /stats, /language, /grouplanguage."

msgid "rules.link"
msgstr "Rules: Classic — https://tesera.ru/images/items/104070/Resistance_V2_rules.pdf; Werewolves — https://boardgamer.ru/pravila-igry-resistance/"

msgid "symbols.text"
msgstr "Board symbols: ✅ successful mission, ❌ failed mission, ⬜ mission not played."

msgid "ping"
msgstr "pong"

msgid "menu.create"
msgstr "Create game"

msgid "menu.join"
msgstr "Join game"

msgid "menu.variant.classic"
msgstr "Classic"

msgid "menu.variant.werewolves"
msgstr "Werewolves"

msgid "menu.missions.3"
msgstr "3 missions"

msgid "menu.missions.5"
msgstr "5 missions"

msgid "menu.start"
msgstr "Start game"

msgid "menu.cancel"
msgstr "Cancel game"

msgid "error.unavailable"
msgstr "This action is no longer available."

msgid "join.private_chat"
msgstr "Start a private chat with the bot, then use /join again."

msgid "group.only"
msgstr "This command can only be used in a group."

msgid "lobby.exists"
msgstr "A lobby or game already exists in this group."

msgid "lobby.created"
msgstr "New game created!"

msgid "lobby.joined"
msgstr "{name} joined the lobby."

msgid "lobby.already_joined"
msgstr "You are already in the lobby."

msgid "lobby.full"
msgstr "The lobby is full. Start the game from the lobby panel."

msgid "lobby.missing"
msgstr "There is no lobby in this group. Create one with the button or /newgame."

msgid "lobby.started"
msgstr "The game has already started."

msgid "lobby.need_players"
msgstr "The lobby needs 5-10 players before it can start."

msgid "lobby.start_forbidden"
msgstr "Only the lobby creator or a group administrator can change settings, start, or cancel the game."

msgid "missions.usage"
msgstr "Classic rules only: choose /missions 3 or /missions 5 before starting."

msgid "missions.updated"
msgstr "Mission count: {count}."

msgid "variant.classic"
msgstr "Classic"

msgid "variant.werewolves"
msgstr "Werewolves"

msgid "variant.updated"
msgstr "Game variant: {variant}."

msgid "game.started"
msgstr "The game has started with {players} players. Check your private chat for your secret role."

msgid "game.cancelled"
msgstr "Game cancelled."

msgid "game.role"
msgstr "Your secret role is {role}."

msgid "game.hidden_players.classic"
msgstr "The spies are: {names}."

msgid "game.hidden_players.werewolves"
msgstr "The werewolves are: {names}."

msgid "round.build.classic"
msgstr "Mission {mission}/{total}. Leader: {leader}. Choose {size} players for the team."

msgid "round.build.werewolves"
msgstr "Round {mission}. Leader: {leader}. Choose {size} players for the patrol."

msgid "team.choose"
msgstr "Choose exactly {size} team members."

msgid "team.confirm"
msgstr "Confirm team"

msgid "team.proposed"
msgstr "Leader {leader} proposed this team: {members}. Vote in private chat."

msgid "team.vote.prompt"
msgstr "Approve the team: {members}?"

msgid "team.vote.yes"
msgstr "Approve"

msgid "team.vote.no"
msgstr "Reject"

msgid "team.vote.approved"
msgstr "Team approved.\nApprove: {approved}\nReject: {rejected}"

msgid "team.vote.rejected.classic"
msgstr "Team rejected ({attempts}/5).\nApprove: {approved}\nReject: {rejected}"

msgid "team.vote.rejected.werewolves"
msgstr "Team rejected ({attempts} this round).\nApprove: {approved}\nReject: {rejected}"

msgid "mission.departed"
msgstr "The team departs: {members}. Its decision is secret."

msgid "mission.prompt"
msgstr "Choose the mission outcome."

msgid "mission.success.classic"
msgstr "Support the mission"

msgid "mission.sabotage.classic"
msgstr "Sabotage the mission"

msgid "mission.success.werewolves"
msgstr "Protect the village"

msgid "mission.sabotage.werewolves"
msgstr "Attack the villagers"

msgid "mission.result.classic.success"
msgstr "The mission succeeded. Sabotages: {sabotages}."

msgid "mission.result.classic.failed"
msgstr "The mission failed. Sabotages: {sabotages}."

msgid "mission.result.werewolves.success"
msgstr "The patrol succeeded: a curse is lifted. Attacks: {sabotages}."

msgid "mission.result.werewolves.failed"
msgstr "The patrol failed: the werewolves attacked. Attacks: {sabotages}."

msgid "game.over"
msgstr "Game over: {winner} win.\n\n{roles}"

msgid "roles"
msgstr "{name}: {role}"

msgid "board.classic"
msgstr "Missions: {missions}\nResistance: {successes}/{wins}\nSpies: {failures}/{wins}\nRejected teams: {rejected}/5\nCurrent mission: {mission}/{total} ({size} players)\nLeader order: {order}"

