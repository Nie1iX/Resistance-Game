msgstr "Защитить деревню"

msgid "mission.sabotage.werewolves"
msgstr "Напасть на жителей"

msgid "mission.result.classic.success"
msgstr "Миссия успешна. Голосов за саботаж: {sabotages}."

msgid "mission.result.classic.failed"
msgstr "Миссия провалена. Голосов за саботаж: {sabotages}."

msgid "mission.result.werewolves.success"
msgstr "Дозор успешен: одно проклятие снято. Следов нападения: {sabotages}."

msgid "mission.result.werewolves.failed"
msgstr "Дозор провален: оборотни напали. Следов нападения: {sabotages}."

msgid "game.over"
msgstr "Игра окончена: победили {winner}.\n\n{roles}"

msgid "roles"
msgstr "{name}: {role}"

msgid "board.classic"
msgstr "Миссии: {missions}\nСопротивление: {successes}/{wins}\nШпионы: {failures}/{wins}\nОтклонённые команды: {rejected}/5\nТекущая миссия: {mission}/{total} ({size} игроков)\nПорядок лидеров: {order}"

msgid "board.werewolves"
msgstr "Осталось проклятий: {curses}\nЗдоровье деревни: {health}\nОтклонённые команды в этом раунде: {rejected}\nТекущий раунд: {round} ({size} игроков)\nПорядок лидеров: {order}"

msgid "stats.votes"
msgstr "Получено голосов: {count}/{total}."

msgid "stats.missing"
msgstr "Активного голосования нет."

msgid "stats.reminder"
msgstr "Пожалуйста, проголосуйте: {players}"

msgid "stats.summary"
msgstr "Ваши игры: {games}\nПобеды: {wins}\n\nИгры группы: {group_games}\nПобеды открытой стороны: {villager_wins}\nПобеды скрытой стороны: {werewolf_wins}"

