msgstr "В этой группе нет лобби. Создайте его кнопкой или командой /newgame."

msgid "lobby.started"
msgstr "Игра уже началась."

msgid "lobby.need_players"
msgstr "Для запуска в лобби должно быть 5–10 игроков."

msgid "lobby.start_forbidden"
msgstr "Менять настройки, запускать или отменять игру может только создатель лобби или администратор группы."

msgid "missions.usage"
msgstr "Только для Classic: до старта выберите /missions 3 или /missions 5."

msgid "missions.updated"
msgstr "Количество миссий: {count}."

msgid "variant.classic"
msgstr "Classic"

msgid "variant.werewolves"
msgstr "Werewolves"

msgid "variant.updated"
msgstr "Вариант игры: {variant}."

msgid "game.started"
msgstr "Игра началась: игроков — {players}. Проверьте личные сообщения, чтобы узнать секретную роль."

msgid "game.cancelled"
msgstr "Игра отменена."

