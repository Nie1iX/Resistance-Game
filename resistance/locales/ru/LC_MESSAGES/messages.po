msgstr "Начать игру"

msgid "menu.cancel"
msgstr "Отменить игру"

msgid "error.unavailable"
msgstr "Это действие больше недоступно."

msgid "join.private_chat"
msgstr "Запустите личный чат с ботом, затем повторите /join."

msgid "group.only"
msgstr "Эта команда работает только в группе."

msgid "lobby.exists"
msgstr "В этой группе уже есть лобби или активная игра."

