msgstr "Одобрить команду: {members}?"

msgid "team.vote.yes"
msgstr "Одобрить"

msgid "team.vote.no"
msgstr "Отклонить"

msgid "team.vote.approved"
msgstr "Команда одобрена.\nЗа: {approved}\nПротив: {rejected}"

msgid "team.vote.rejected.classic"
msgstr "Команда отклонена ({attempts}/5).\nЗа: {approved}\nПротив: {rejected}"

msgid "team.vote.rejected.werewolves"
msgstr "Команда отклонена ({attempts} в этом раунде).\nЗа: {approved}\nПротив: {rejected}"

