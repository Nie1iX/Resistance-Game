msgstr "Новая игра создана!"

msgid "lobby.joined"
msgstr "{name} присоединился к лобби."

msgid "lobby.already_joined"
msgstr "Вы уже в лобби."

msgid "lobby.full"
msgstr "Лобби заполнено. Запустите игру из панели лобби."

