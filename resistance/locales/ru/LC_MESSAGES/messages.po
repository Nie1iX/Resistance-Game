msgid "start.description"
msgstr "«Сопротивление» — игра на социальную дедукцию для 5–10 игроков. Добавьте бота в группу и используйте кнопку ниже или /newgame."

msgid "help.commands"
msgstr "Команды: /newgame, /join, /missions, /startgame, /cancelgame, /board, /votes, /calltovote, /stats, /language, /grouplanguage."

msgid "rules.link"
msgstr "Правила: Classic — https://tesera.ru/images/items/104070/Resistance_V2_rules.pdf; Werewolves — https://boardgamer.ru/pravila-igry-resistance/"

msgid "symbols.text"
msgstr "Символы: ✅ успешная миссия, ❌ проваленная миссия, ⬜ миссия ещё не сыграна."

msgid "ping"
msgstr "pong"

msgid "menu.create"
msgstr "Создать игру"

msgid "menu.join"
msgstr "Присоединиться"

msgid "menu.variant.classic"
msgstr "Classic"

msgid "menu.variant.werewolves"
msgstr "Werewolves"

msgid "menu.missions.3"
msgstr "3 миссии"

